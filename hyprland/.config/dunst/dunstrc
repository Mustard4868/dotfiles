[global]
frame_color = "#a6e3a1"
separator_color= frame
highlight = "#a6e3a1"
corner_radius = 10
origin = top-right
offset = (15, 15)
font = "Noto Sans"
icon_theme = "Papirus-Dark"

[urgency_low]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_normal]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_critical]
background = "#1e1e2e"
foreground = "#cdd6f4"
frame_color = "#fab387"
