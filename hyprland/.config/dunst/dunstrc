[global]
frame_color = "#cba6f7"
separator_color= frame
highlight = "#cba6f7"
corner_radius = 10
origin = top-right
offset = (15, 15)
font = "Noto Sans"
icon_theme = "Papirus-Dark"

[urgency_low]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_normal]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_critical]
background = "#1e1e2e"
foreground = "#cdd6f4"
frame_color = "#f38ba8"
