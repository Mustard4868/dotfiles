//                     ‚ĖĎ ‚ĖĎ           ‚ĖĎ                    
{
    "layer": "top",
    "spacing": 4,
    "width": "",
    "height": "",

    "modules-left": [
        "custom/power",
        "custom/badge",
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "pulseaudio",
        "battery"
    ],

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "default": "‚óč",
            "active": "‚óŹ"
        },
        "persistent-workspaces": {
            "*": 3
        }
    },

    "custom/power": {
        "format":"   ",
        "on-click": "wlogout",
        "tooltip": "true",
        "tooltip-format": "wlogout"
    },

    "battery": {
        "bat": "BAT0",
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-icons": ["ůįāĄ", "ůįĀĽ", "ůįĀľ", "ůįĀĹ", "ůįĀĺ", "ůįĀŅ", "ůįāÄ", "ůįāĀ", "ůįāā", "ůįĀĻ"],
        "format-charging": "ůįāĄ {capacity}%",
        "format-full": "ůįāĄ {capacity}%",
        "tooltip": "true",
        "tooltip-format": "{capacity}%"
    },

    "clock": {
        "format": "{:%H:%M}",
        "tooltip": "true",
        "tooltip-format": "{:%A, %d %B %Y}"
    },

    "pulseaudio": {
        //"scroll-step": 1,
        "format": "{icon}    {volume}%",
        "format-bluetooth": "{icon}    {volume}%ÔäĒ",
        "format-muted": "ÔÄ¶  mute",
        "format-icons": {
            "headphones": "ÔÄ•",
            "handsfree": "ÔĖź",
            "headset": "ÔĖź",
            "phone": "Ôāē",
            "portable": "Ôāē",
            "car": "ÔÜĻ",
            "default": ["ÔÄß", "ÔÄ®"]
        },
        "on-click": "pavucontrol"
    }
}
